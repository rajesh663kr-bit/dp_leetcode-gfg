class Solution {
public:
vector<int>dp;

int f(vector<int>& cost , int n)
{
    if(n<2) return cost[n];
    if(dp[n]!=-1) return dp[n];


    return dp[n]= cost[n]+(min(f(cost, n-1) , f(cost, n-2)));


}


    int minCostClimbingStairs(vector<int>& cost) {
        int n= cost.size();

        int sum=0;
        dp.resize( n+1, -1);

        return min(f(cost, n-1),f(cost , n-2));
    }
};
