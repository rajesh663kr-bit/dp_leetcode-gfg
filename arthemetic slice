class Solution {
public:
vector<int>dp;
int f(vector<int>& nums , int i)
{
    if(i<2) return 0;
    if(dp[i]!=-1) return dp[i];
    int ans =0;
    if(nums[i]- nums[i-1]==nums[i-1]- nums[i-2])
    {
        ans=1+f(nums , i-1);
    }
    return dp[i]= ans;
}
    int numberOfArithmeticSlices(vector<int>& nums) {
        int n= nums.size();
        int ans=0;
        dp.resize(n+1 , -1);
       for(int i=2;i<n;i++)
       {
         ans+= f(nums , i);
       }
        return ans;
    }
};
